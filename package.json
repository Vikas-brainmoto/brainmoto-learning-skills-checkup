{
  "name": "brainmoto-learning-skills-checkup",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed": "tsx scripts/seed.ts",
    "seed:question-sets": "tsx scripts/seed-question-sets.ts",
    "schools:import": "tsx scripts/import-schools.ts",
    "schools:import:dry": "tsx scripts/import-schools.ts --dry-run",
    "lint": "next lint",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test:unit": "vitest run tests/scoring tests/checkup tests/report tests/email --config vitest.config.ts",
    "test:api": "vitest run tests/api --config vitest.config.ts",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@fontsource/poppins": "^5.2.7",
    "@prisma/client": "^6.19.3",
    "@sparticuz/chromium": "^147.0.1",
    "@vercel/blob": "^2.3.3",
    "next": "latest",
    "puppeteer-core": "^24.41.0",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "prettier": "latest",
    "prisma": "^6.19.3",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
