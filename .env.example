# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
REPORT_TOKEN_SECRET=replace-with-a-long-random-secret

# Database (Neon/Postgres)
DATABASE_URL=postgresql://username:password@host:5432/brainmoto_checkup?sslmode=require

# Email (Resend)
# Use a Resend API key with email-sending permission.
RESEND_API_KEY=re_example_key
# Must be from your verified sending domain in Resend.
RESEND_FROM_EMAIL=Brainmoto <reports@mailer.brainmoto.in>

# File storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_example_token

# Internal admin
INTERNAL_ADMIN_KEY=replace-with-a-long-random-admin-key
